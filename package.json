{
  "name": "moonvault",
  "version": "2.0.0",
  "description": "MoonVault Video & Audio Downloader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:renderer": "webpack --mode production",
    "watch:renderer": "webpack --mode development --watch",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "publish:win": "npm run build:renderer && electron-builder --win --publish always",
    "publish:linux": "npm run build:renderer && electron-builder --linux --publish always",
    "publish:win:ci": "electron-builder --win --publish always",
    "publish:linux:ci": "electron-builder --linux --publish always"
  },
  "keywords": [
    "youtube",
    "downloader",
    "yt-dlp",
    "electron",
    "baixador",
    "twitter"
  ],
  "author": "MoonVault",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.moonvault.app",
    "productName": "MoonVault",
    "publish": {
      "provider": "github",
      "owner": "siirmoon",
      "repo": "MoonVault"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/index.html",
      "renderer/styles.css",
      "renderer/assets/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "renderer/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MoonVault",
      "runAfterFinish": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "renderer/assets/icon.png"
    }
  }
}
